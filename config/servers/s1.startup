/etc/init.d/networking restart

ip route add 192.168.1.0/24 via 23.75.200.1
ip route add 50.0.0.0/24 via 23.75.200.1
ip route add 193.201.28.0/23 via 23.75.200.1
ip route add 100.0.0.0/24 via 23.75.200.1
ip route add 145.97.4.96/27 via 23.75.200.1
ip route add 151.0.45.0/31 via 23.75.200.1
ip route add 192.168.88.0/24 via 23.75.200.1

/etc/init.d/ssh restart

useradd ubuntu -m
echo -e 'password\npassword\n' | passwd ubuntu

mkdir /home/ubuntu/.ssh
touch /home/ubuntu/.ssh/authorized_keys
chown ubuntu:ubuntu /home/ubuntu/.ssh
chmod 700 .ssh
chown ubuntu:ubuntu /home/ubuntu/.ssh/authorized_keys
chmod 600 .ssh/authorized_keys
cat /shared/id_rsa.pub >> /home/ubuntu/.ssh/authorized_keys


