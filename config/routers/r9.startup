echo 'INTERFACESv4="eth1"' > /etc/default/isc-dhcp-server
echo 'INTERFACESv6=""' >> /etc/default/isc-dhcp-server

/etc/init.d/networking restart
/etc/init.d/isc-dhcp-server start

# --- Routing ---
ip route add 192.168.1.0/24 via 145.97.4.97
ip route add 50.0.0.0/24 via 145.97.4.97
ip route add 193.201.28.0/23 via 145.97.4.97
ip route add 100.0.0.0/24 via 145.97.4.97
ip route add 23.75.0.0/16 via 145.97.4.97

ip route add 151.0.45.0/31 via 145.97.4.97
ip route add 192.168.88.0/24 via 145.97.4.97

# --- NAT Rules ---
sysctl -w net.ipv4.ip_forward=1

iptables -F
iptables -t nat -F

iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE

# Existing DNAT Rules
#iptables -A PREROUTING -t nat -p tcp -i eth1 --dport 1194 -j DNAT --to-destination 192.168.1.3:7000
#iptables -A PREROUTING -t nat -p tcp -i eth1 --dport 1194 -j DNAT --to-destination 192.168.1.2:7000

# --- Firewall Rules ---

iptables -P FORWARD DROP

# 2. *** NEW: Allow VPN Traffic on Port 7070 ***
iptables -A FORWARD -p tcp --dport 7070 -j ACCEPT

#iptables -A FORWARD -o eth1 -m state --state NEW -j DROP
#iptables -A INPUT -o eth1 -m state --state NEW -j DROP

iptables -A FORWARD -s 192.168.1.0/24 -j ACCEPT

iptables -A FORWARD -d 192.168.1.0/24 -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT

service iptables restart
