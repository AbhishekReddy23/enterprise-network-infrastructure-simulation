/etc/init.d/networking restart


ip route add 100.0.0.0/24 via 193.201.29.254
ip route add 192.168.1.0/24 via 50.0.0.8

ip route add 145.97.4.96/27 via 193.201.29.254
ip route add 23.75.0.0/16 via 193.201.29.254
ip route add 151.0.45.0/31 via 193.201.29.254
